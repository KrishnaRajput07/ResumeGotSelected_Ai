INDIA_RUN_ROOT=D:\India_Run

OLLAMA_MODELS=D:\India_Run\models\ollama

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=cpu

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_ENABLED=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu
RERANKER_TOP_N=5

# ── Pipeline thresholds ───────────────────────────────────────────────────────
SHORTLIST_TOP_K=40
SHORTLIST_SIMILARITY_FLOOR=0.30
QA_RETRIEVE_TOP_N=5
