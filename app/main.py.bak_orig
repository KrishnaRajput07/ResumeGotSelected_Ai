def score_color(score: float) -> str:
    if score >= 7: return "#34d399"
    if score >= 5: return "#fbbf24"
    return "#fb7185"

def score_pill_cls(score: float) -> str:
    if score >= 7: return "pill pill-high"
    if score >= 5: return "pill pill-mid"
    return "pill pill-low"

def conf_pill_cls(conf: str) -> str:
    m = {"high": "pill-high", "medium": "pill-mid", "low": "pill-low"}
    return f"pill {m.get(conf.lower(), 'pill-low')}"

def pill_html(text: str, cls: str) -> str:
    return f'<span class="{cls}">{text}</span>'


def brand_wordmark(size: str = "1.1rem", light_bg: bool = True) -> str:
    pink_color = "#d81159" if light_bg else "#ff80c7"
    black_color = "#111111" if light_bg else "#fffaf2"
    return (
        f'<span class="brand-wordmark" style="font-size:{size}; font-weight:900;">'
        f'<span style="color:{pink_color};">ResumeGot</span>'
        f'<span style="color:{black_color};">Selected.Ai</span>'
        '</span>'
    )


def render_loading_stage_html(title: str, detail: str, chip: str = "LIVE MATCH RUN") -> str:
    return f"""
    <div class="loading-stage">
      <div class="loading-topline">
        <div style="display:flex; align-items:center; gap:12px;">
          <span class="brand-mark" style="background:#fffaf2; color:#d81159; box-shadow: 4px 4px 0 #ffbf00;">R</span>
          {brand_wordmark("1.05rem", light_bg=False)}
        </div>
        <span class="loading-chip">{chip}</span>
      </div>
      <div class="loading-title"><span class="hot">{title}</span><br>ranking with receipts.</div>
      <div class="loading-detail">{detail}</div>
      <div class="loading-rail" aria-hidden="true">
        <div class="loading-scan-row"><span></span></div>
        <div class="loading-scan-row"><span></span></div>
        <div class="loading-scan-row"><span></span></div>
        <div class="loading-scan-row"><span></span></div>
      </div>
    </div>
    """


def render_loading_stage(title: str, detail: str, chip: str = "LIVE MATCH RUN") -> None:
    st.markdown(render_loading_stage_html(title, detail, chip), unsafe_allow_html=True)

