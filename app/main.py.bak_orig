# Page 1: Upload
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def page_upload():
    # Hero banner
    st.markdown(f"""
    <div class="hero-banner">
      <div class="hero-title">{brand_wordmark("2rem")}</div>
      <div class="hero-sub">Upload a job description and candidate resumes, then get a sharper shortlist with evidence attached.<br>
      Built for private, local screening that feels fast, deliberate, and reviewable.</div>
    </div>
    """, unsafe_allow_html=True)

    # System status (collapsed by default)
    with st.expander("├░┼ИРђЮ┬Д System Status", expanded=False):
        c1, c2, c3 = st.columns(3)
        with c1:
            st.markdown("**LLM ├бРѓгРђЮ Ollama**")
            if st.button("├░┼ИРђЮРђъ Test Connection", key="refresh_health"):
                with st.spinner("Checking..."):
                    ok = llm_client.check_connectivity()
                st.success("├б┼ЊРђд Connected") if ok else st.error("├б┬Ю┼њ Not reachable")
            st.caption(f"Model: `{settings.ollama_model}`")
            st.caption(f"URL: `{settings.ollama_base_url}`")
        with c2:
            st.markdown("**Embedding Model**")
            cache_dir = Path(settings.embeddings_cache_dir)
            cache_ok = cache_dir.exists() and any(cache_dir.iterdir()) if cache_dir.exists() else False
            st.success("├б┼ЊРђд Cache ready") if cache_ok else st.warning("├б┼А┬а├»┬И┬Ј Will download on first run")
            st.caption(f"Model: `{settings.embedding_model}`")
        with c3:
            st.markdown("**Data Directories**")
            dirs_ok = all(Path(d).exists() for d in [settings.uploads_dir, settings.runs_dir])
            st.success("├б┼ЊРђд Directories ready") if dirs_ok else st.warning("├б┼А┬а├»┬И┬Ј Will be created automatically")

    st.markdown("---")

    # Demo mode
    fixtures_dir = Path(__file__).resolve().parents[1] / "tests" / "fixtures"
    if fixtures_dir.exists():
        col_demo, _ = st.columns([1, 3])
        with col_demo:
            if st.button("├░┼И┼й┬« Load Demo Data", help="Uses fixture files ├бРѓгРђЮ requires Ollama"):
                demo_files = list(fixtures_dir.glob("resume_*.txt"))
                demo_jd = fixtures_dir / "jd_software_engineer.txt"
                if demo_jd.exists() and demo_files:
                    st.session_state.jd_file_path = str(demo_jd)
                    st.session_state.resume_file_paths = [str(f) for f in demo_files]
                    try:
                        with st.spinner("Loading demo rubric..."):
                            result = run_step1_only(demo_jd)
                        st.session_state.jd_parse_result = result
                        st.session_state.page = "calibrate"
                        st.rerun()
                    except Exception as e:
                        st.error(f"Demo failed (Ollama required): {e}")
                else:
                    st.warning("Demo fixtures not found.")

    # ├бРђЮРѓг├бРђЮРѓг Mode A: PDF/DOCX Resumes ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    st.markdown("## ├░┼ИРђюРђъ Mode A ├бРѓгРђЮ Job Description + Resume Files")
    st.markdown('<div class="card">', unsafe_allow_html=True)

    col1, col2 = st.columns([1, 1], gap="large")
    with col1:
        st.markdown("**Job Description** *(PDF / DOCX / TXT)*")
        jd_file = st.file_uploader(
            "Upload JD", type=["pdf", "docx", "txt"], key="jd_uploader",
            help="Parses the role and generates an evidence-first rubric.",
            label_visibility="collapsed",
        )
        if jd_file:
            st.markdown(f'<div class="stat-badge teal">├б┼ЊРђю {jd_file.name}</div>', unsafe_allow_html=True)

    with col2:
        st.markdown("**Candidate Resumes** *(multiple files OK)*")
        resume_files = st.file_uploader(
            "Upload Resumes", type=["pdf", "docx", "txt"],
            accept_multiple_files=True, key="resume_uploader",
            help="Upload all resumes at once.",
            label_visibility="collapsed",
        )
        if resume_files:
            st.markdown(f'<div class="stat-badge teal">├б┼ЊРђю {len(resume_files)} resume(s) ready</div>', unsafe_allow_html=True)

    st.markdown('</div>', unsafe_allow_html=True)

    can_proceed = jd_file is not None and len(resume_files or []) >= 1
    col_btn, col_note = st.columns([2, 3])
    with col_btn:
        if st.button("├░┼И┼АРѓг Parse JD & Generate Rubric", disabled=not can_proceed, type="primary"):
            with st.spinner("Parsing JD and generating AI rubric├бРѓг┬д (30├бРѓгРђю60s)"):
                upload_dir = Path(settings.uploads_dir) / uuid.uuid4().hex[:8]
                upload_dir.mkdir(parents=True, exist_ok=True)
                jd_path = upload_dir / jd_file.name
                jd_path.write_bytes(jd_file.getvalue())
                resume_paths = []
                for rf in resume_files:
                    rp = upload_dir / rf.name
                    rp.write_bytes(rf.getvalue())
                    resume_paths.append(str(rp))
                st.session_state.jd_file_path = str(jd_path)
                st.session_state.resume_file_paths = resume_paths
                try:
                    result = run_step1_only(jd_path)
                    st.session_state.jd_parse_result = result
                    st.session_state.page = "calibrate"
                    st.rerun()
                except Exception as e:
                    st.error(f"├б┬Ю┼њ JD parsing failed: {e}")
    with col_note:
        if not can_proceed:
            st.info("├░┼ИРђю┼њ Upload a JD and at least one resume to continue.")

    st.markdown("---")

    # ├бРђЮРѓг├бРђЮРѓг Mode B: JSONL Pool ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    st.markdown("## ├░┼ИРђћРђъ├»┬И┬Ј Mode B ├бРѓгРђЮ Structured Candidate Pool (JSONL)")
    st.markdown("""
    <div class="card-accent" style="margin-bottom:1rem;">
      <div style="font-size:0.88rem; color:#ff80c7; font-weight:600; margin-bottom:6px;">├б┼Њ┬д High-volume pool mode</div>
      <div style="font-size:0.83rem; color:#4d463d;">Upload a <code>candidates.jsonl</code> file (up to 100,000 structured profiles).
      Behavioral scoring runs on <strong>all</strong> candidates without LLM calls.
      Full evidence-grounded scoring runs on the top-N shortlisted candidates.</div>
    </div>
    """, unsafe_allow_html=True)

    st.markdown('<div class="card">', unsafe_allow_html=True)
    col3, col4 = st.columns([1, 1], gap="large")
    with col3:
        st.markdown("**Job Description** *(PDF / DOCX / TXT)*")
        jsonl_jd_file = st.file_uploader(
            "JD for pool", type=["pdf", "docx", "txt"], key="jsonl_jd_uploader",
            label_visibility="collapsed",
        )
        if jsonl_jd_file:
            st.markdown(f'<div class="stat-badge teal">├б┼ЊРђю {jsonl_jd_file.name}</div>', unsafe_allow_html=True)

    with col4:
        st.markdown("**Candidate Pool** *(JSONL format)*")
        jsonl_file = st.file_uploader(
            "Candidate pool", type=["jsonl", "json"], key="jsonl_uploader",
            help="Upload candidates.jsonl ├бРѓгРђЮ 100K profiles supported.",
            label_visibility="collapsed",
        )
        if jsonl_file:
            st.markdown(f'<div class="stat-badge teal">├б┼ЊРђю {jsonl_file.name}</div>', unsafe_allow_html=True)
    st.markdown('</div>', unsafe_allow_html=True)

    can_proceed_jsonl = jsonl_jd_file is not None and jsonl_file is not None
    col_btn2, col_note2 = st.columns([2, 3])
    with col_btn2:
        if st.button("├░┼И┼АРѓг Parse JD & Score Candidate Pool", disabled=not can_proceed_jsonl, key="btn_jsonl_start", type="primary"):
            with st.spinner("Parsing JD and generating AI rubric├бРѓг┬д"):
                upload_dir = Path(settings.uploads_dir) / uuid.uuid4().hex[:8]
                upload_dir.mkdir(parents=True, exist_ok=True)
                jd_path = upload_dir / jsonl_jd_file.name
                jd_path.write_bytes(jsonl_jd_file.getvalue())
                jsonl_path = upload_dir / jsonl_file.name
                jsonl_path.write_bytes(jsonl_file.getvalue())
                st.session_state.jd_file_path = str(jd_path)
                st.session_state.jsonl_file_path = str(jsonl_path)
                st.session_state.resume_file_paths = []
                st.session_state.is_jsonl_mode = True
                try:
                    result = run_step1_only(jd_path)
                    st.session_state.jd_parse_result = result
                    st.session_state.page = "calibrate"
                    st.rerun()
                except Exception as e:
                    st.error(f"├б┬Ю┼њ JD parsing failed: {e}")
    with col_note2:
        if not can_proceed_jsonl:
            st.info("├░┼ИРђю┼њ Upload a JD and a JSONL candidate pool to use this mode.")


# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
# Page 2: Calibrate
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def page_calibrate():
    result = st.session_state.jd_parse_result
    if not result:
        st.warning("├б┼А┬а├»┬И┬Ј Please upload and parse a JD first.")
        st.session_state.page = "upload"
        st.rerun()
        return

    rubric = result.rubric

    st.markdown(f"""
    <div class="hero-banner">
      <div class="hero-title">├б┼АРёб├»┬И┬Ј Calibrate Rubric</div>
      <div class="hero-sub">Evaluation rubric for <strong>{rubric.job_title}</strong>.<br>
      Tune weights, gates, and bonus sensitivity before the shortlist run starts.</div>
    </div>
    """, unsafe_allow_html=True)

    if result.warnings:
        for w in result.warnings:
            st.warning(w)

    with st.expander("├░┼ИРђюРђъ View Extracted JD Text", expanded=False):
        st.code(result.jd_text[:3000], language=None)

    st.markdown("---")

    # Criteria
    st.markdown("## ├░┼ИРђю┼а Weighted Criteria")
    st.markdown("""
    <div style="font-size:0.83rem; color:#4d463d; margin-bottom:1rem; padding:10px 14px;
    background:rgba(255,128,199,0.06); border-radius:8px; border-left:3px solid #111111;">
      ├░┼ИРђЎ┬А Adjust sliders to set relative importance. Weights auto-normalize to 1.0.
      Check <strong>├б┬Г┬љ Priority</strong> to apply a ├ЃРђћ1.15 boost to that criterion.
    </div>
    """, unsafe_allow_html=True)

    updated_criteria = []
    new_weights = []
    for i, criterion in enumerate(rubric.weighted_criteria):
        st.markdown('<div class="card">', unsafe_allow_html=True)
        col_main, col_star = st.columns([5, 1])
        with col_main:
            cat_color = "#ffbf00" if "Hard" in criterion.category else "#ff80c7"
            st.markdown(
                f"<div style='font-size:0.95rem; font-weight:700; color:#111111; margin-bottom:2px;'>{criterion.criterion}</div>"
                f"<div style='display:inline-flex; align-items:center; gap:6px; margin-bottom:8px;'>"
                f"<span style='background:rgba({','.join(str(int(cat_color[i:i+2],16)) for i in (1,3,5))},0.15); "
                f"color:{cat_color}; font-size:0.72rem; font-weight:600; padding:2px 8px; border-radius:100px; "
                f"border:1px solid rgba({','.join(str(int(cat_color[i:i+2],16)) for i in (1,3,5))},0.3);'>{criterion.category}</span>"
                f"<span style='color:#948a7c; font-size:0.78rem;'>Weight: {criterion.weight:.2f}</span></div>",
                unsafe_allow_html=True,
            )
            st.caption(f"*{criterion.rationale}*")
            new_weight = st.slider(
                f"w{i}", min_value=0.01, max_value=0.50,
                value=float(criterion.weight), step=0.01,
                key=f"weight_{criterion.id}", label_visibility="collapsed", format="%.2f",
            )
        with col_star:
            st.markdown("<br>", unsafe_allow_html=True)
            is_priority = st.checkbox("├б┬Г┬љ Priority", key=f"priority_{criterion.id}", help="Boost ├ЃРђћ1.15")

        final_weight = new_weight * 1.15 if is_priority else new_weight
        new_weights.append(final_weight)
        updated_criteria.append(WeightedCriterion(
            id=criterion.id, criterion=criterion.criterion,
            category=criterion.category, weight=final_weight,
            rationale=criterion.rationale,
        ))
        st.markdown('</div>', unsafe_allow_html=True)

    # Auto-normalize
    normalized_weight_total = sum(c.weight for c in updated_criteria)
    if abs(normalized_weight_total - 1.0) > 0.02:
        for c in updated_criteria:
            c.weight = round(c.weight / normalized_weight_total, 6)

    display_total = sum(c.weight for c in updated_criteria)
    col_wt, _ = st.columns([1, 4])
    with col_wt:
        if 0.98 <= display_total <= 1.02:
            st.success(f"├б┼ЊРђд Weights sum: {display_total:.2f}")
        else:
            st.warning(f"├б┼А┬а├»┬И┬Ј Weights: {display_total:.2f} (auto-normalizing)")

    st.markdown("---")

    # Hard Gates
    st.markdown("## ├░┼И┼А┬Д Hard Gates")
    updated_gates = []
    if rubric.hard_gates:
        st.markdown("""
        <div style="font-size:0.83rem; color:#4d463d; margin-bottom:1rem; padding:10px 14px;
        background:rgba(251,113,133,0.06); border-radius:8px; border-left:3px solid #fb7185;">
          ├░┼И┼А┬Д <strong>Strict</strong> = candidate excluded if not met. <strong>Flexible</strong> = heavy penalty but still ranked.
        </div>
        """, unsafe_allow_html=True)
        for i, gate in enumerate(rubric.hard_gates):
            st.markdown('<div class="card">', unsafe_allow_html=True)
            col_g, col_s = st.columns([4, 1])
            with col_g:
                st.markdown(f"<div style='font-size:0.92rem; font-weight:600; color:#111111;'>├░┼ИРђЮРђЎ {gate.criterion}</div>", unsafe_allow_html=True)
            with col_s:
                strict = st.toggle("Strict", value=gate.strict, key=f"gate_strict_{i}_{gate.criterion[:20]}")
            updated_gates.append(HardGate(criterion=gate.criterion, strict=strict))
            st.markdown('</div>', unsafe_allow_html=True)
    else:
        st.info("├бРђъ┬╣├»┬И┬Ј No hard gates identified in this JD.")

    st.markdown("---")

    # Bonus Sensitivity
    st.markdown("## ├░┼И┼њ┼И Bonus Signal Sensitivity")
    st.markdown("""
    <div style="font-size:0.83rem; color:#4d463d; margin-bottom:1rem;">
      Controls how much weight exceptional achievements (outside the rubric) add to the final score.
    </div>
    """, unsafe_allow_html=True)
    bonus_sensitivity = st.radio(
        "Bonus Sensitivity", options=["off", "low", "medium", "high"],
        index=2, horizontal=True, label_visibility="collapsed",
    )

    st.markdown("---")

    # JSONL-specific controls
    if st.session_state.get("is_jsonl_mode"):
        st.markdown("## ├░┼ИРђЮРђъ JSONL Pool Settings")
        jsonl_top_n = st.slider(
            "LLM deep-scoring top N candidates",
            min_value=10, max_value=200,
            value=st.session_state.get("jsonl_llm_top_n", 50), step=10,
            key="slider_jsonl_top_n",
            help="Behavioral scoring runs on ALL candidates. LLM scoring runs on top N only.",
        )
        st.session_state.jsonl_llm_top_n = jsonl_top_n
        st.markdown(f"""
        <div class="card-accent">
          <div style="font-size:0.88rem; color:#ff80c7; font-weight:600;">├░┼ИРђЮРђъ JSONL Mode Active</div>
          <div style="font-size:0.82rem; color:#4d463d; margin-top:4px;">
            Fast behavioral scoring runs on <strong>all</strong> candidates in the pool.<br>
            Evidence-grounded LLM scoring runs on the top <strong>{jsonl_top_n}</strong> shortlisted candidates.
          </div>
        </div>
        """, unsafe_allow_html=True)
        candidate_pool_info = "JSONL candidate pool"
    else:
        candidate_pool_info = f"{len(st.session_state.resume_file_paths)} resume(s)"

    resume_count = len(st.session_state.resume_file_paths)
    if resume_count > 30:
        criteria_count = len(updated_criteria)
        est_minutes = resume_count * criteria_count * 0.5
        st.warning(
            f"├б┼А┬а├»┬И┬Ј {resume_count} resumes ├ЃРђћ {criteria_count} criteria ├бРђ░╦є {est_minutes:.0f} min estimated. "
            f"Consider reducing SHORTLIST_TOP_K for faster results."
        )

    col_ev, col_back = st.columns([2, 1])
    with col_ev:
        if st.button(f"├б┼А┬А Evaluate {candidate_pool_info} ├бРѓгРђЮ Freeze Rubric & Start", type="primary"):
            total_w = sum(c.weight for c in updated_criteria)
            for c in updated_criteria:
                c.weight = round(c.weight / total_w, 6)
            try:
                frozen = FrozenRubric(
                    job_title=rubric.job_title,
                    hard_gates=updated_gates,
                    weighted_criteria=updated_criteria,
                    bonus_sensitivity=bonus_sensitivity,
                ).freeze()
                st.session_state.frozen_rubric = frozen
                st.session_state.progress_updates = []
                st.session_state.run_complete = False
                st.session_state.run_error = None
                st.session_state.pipeline_run = None
                st.session_state.pop("pipeline_thread", None)
                st.session_state.pop("progress_q", None)
                st.session_state.pop("pipeline_start_time", None)
                st.session_state.page = "processing"
                st.rerun()
            except Exception as e:
                st.error(f"├б┬Ю┼њ Rubric validation failed: {e}")
    with col_back:
        if st.button("├бРђа┬љ Back to Upload"):
            st.session_state.page = "upload"
            st.rerun()


# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
# Page 3: Processing
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def page_processing():
    frozen_rubric = st.session_state.frozen_rubric
    if not frozen_rubric:
        st.session_state.page = "calibrate"
        st.rerun()
        return

    st.markdown(f"""
    <div class="hero-banner">
      <div class="hero-title">Selection run in motion</div>
      <div class="hero-sub">Evaluating candidates for <strong>{frozen_rubric.job_title}</strong>.<br>
      The rubric is locked, so every profile is judged on the same evidence.</div>
    </div>
    """, unsafe_allow_html=True)

    loading_placeholder = st.empty()
    if not st.session_state.run_complete:
        loading_placeholder.markdown(
            render_loading_stage_html(
                "Reading the field",
                "ResumeGotSelected.Ai is parsing signals, checking evidence, and building a ranked shortlist without breaking the visual flow."
            ),
            unsafe_allow_html=True
        )

    if not st.session_state.run_complete and st.session_state.pipeline_run is None:
        if "pipeline_thread" not in st.session_state:
            progress_q = queue.Queue()
            st.session_state.progress_q = progress_q

            # Extract session state values outside the background thread since st.session_state is not thread-local accessible there
            jd_file_path = st.session_state.jd_file_path
            is_jsonl_mode = st.session_state.get("is_jsonl_mode", False)
            jsonl_file_path = st.session_state.get("jsonl_file_path")
            jsonl_llm_top_n = st.session_state.get("jsonl_llm_top_n", settings.jsonl_llm_deep_score_top_n)
            resume_file_paths = st.session_state.resume_file_paths

            def run_pipeline_thread():
                def progress_cb(update: ProgressUpdate):
                    progress_q.put(update)
                if is_jsonl_mode:
                    run = run_jsonl_pipeline(
                        jd_file_path=jd_file_path,
                        jsonl_path=jsonl_file_path,
                        frozen_rubric=frozen_rubric,
                        progress_cb=progress_cb,
                        llm_deep_score_top_n=jsonl_llm_top_n,
                    )
                else:
                    run = run_full_pipeline(
                        jd_file_path=jd_file_path,
                        resume_file_paths=resume_file_paths,
                        frozen_rubric=frozen_rubric,
                        progress_cb=progress_cb,
                    )
                progress_q.put(run)

            thread = threading.Thread(target=run_pipeline_thread, daemon=True)
            thread.start()
            st.session_state.pipeline_thread = thread
            pipeline_start_time = time.time()
            st.session_state.pipeline_start_time = pipeline_start_time
        else:
            progress_q = st.session_state.progress_q
            thread = st.session_state.pipeline_thread
            pipeline_start_time = st.session_state.pipeline_start_time

        step_names = {
            3: "Resume Ingestion & Indexing",
            4: "Embedding Shortlisting",
            5: "Evidence-Grounded Scoring",
            6: "Parallel Analysis Passes",
            7: "Final Scoring & Ranking",
            8: "Output Generation",
        }
        if st.session_state.get("is_jsonl_mode"):
            step_names[2] = "JSON Loading & Behavioral Scoring"

        step_status = {k: "pending" for k in step_names}
        step_placeholders = {}

        # Pipeline step tracker
        st.markdown("## Pipeline Steps")
        st.markdown('<div class="card">', unsafe_allow_html=True)
        for step_num in sorted(step_names):
            step_placeholders[step_num] = st.empty()
        st.markdown('</div>', unsafe_allow_html=True)

        col_prog, col_detail = st.columns([2, 1])
        with col_prog:
            progress_bar = st.progress(0, text="Initializing pipeline├бРѓг┬д")
        with col_detail:
            elapsed_ph = st.empty()

        detail_placeholder = st.empty()
        log_container = st.expander("├░┼ИРђюРђ╣ Live Log", expanded=False)
        with log_container:
            log_placeholder = st.empty()

        log_lines = []
        total_steps = len(step_names)
        completed_steps = 0

        while thread.is_alive() or not progress_q.empty():
            elapsed = time.time() - pipeline_start_time
            elapsed_ph.markdown(f"<div style='text-align:right; font-size:0.82rem; color:#948a7c; padding-top:12px;'>├б┬Ј┬▒ {elapsed:.0f}s elapsed</div>", unsafe_allow_html=True)

            if elapsed > 600:
                st.session_state.run_error = "Pipeline timed out after 10 minutes."
                break
            try:
                item = progress_q.get(timeout=0.5)
            except queue.Empty:
                _render_step_tracker(step_status, step_placeholders, step_names)
                time.sleep(0.3)
                continue

            from pipeline.orchestrator import PipelineRun
            if isinstance(item, PipelineRun):
                st.session_state.pipeline_run = item
                st.session_state.run_complete = True
                if item.errors:
                    st.session_state.run_error = item.errors[0]
                break

            update: ProgressUpdate = item
            if update.error:
                st.session_state.run_error = update.error
                break

            if update.step in step_status:
                if update.done:
                    step_status[update.step] = "done"
                    completed_steps += 1
                else:
                    step_status[update.step] = "running"

            progress_pct = completed_steps / total_steps
            if update.total > 0:
                sub_progress = (update.current / update.total) / total_steps
                progress_pct = min((completed_steps) / total_steps + sub_progress / total_steps, 1.0)

            progress_bar.progress(
                min(progress_pct, 1.0),
                text=f"Step {update.step} of {total_steps}: {update.step_name}"
            )
            # Dynamically update the premium loading stage panel
            loading_placeholder.markdown(
                render_loading_stage_html(
                    update.step_name,
                    update.detail,
                    chip=f"STEP {update.step} OF {total_steps}"
                ),
                unsafe_allow_html=True
            )

            detail_placeholder.markdown(
                f"<div style='font-size:0.85rem; color:#d81159; padding:6px 0;'>Рє│ {update.detail}</div>",
                unsafe_allow_html=True,
            )

            if update.detail:
                log_lines.append(f"[{elapsed:.1f}s] Step {update.step}: {update.detail}")
                with log_container:
                    log_placeholder.text_area(
                        "Log", value="\n".join(log_lines[-25:]),
                        height=180, disabled=True, label_visibility="collapsed",
                    )

            _render_step_tracker(step_status, step_placeholders, step_names)
            time.sleep(0.1)

    if st.session_state.run_error:
        st.error(f"├б┬Ю┼њ Pipeline error: {st.session_state.run_error}")
        if st.button("├бРђа┬љ Back to Calibration"):
            st.session_state.page = "calibrate"
            st.rerun()
        return

    if st.session_state.run_complete and st.session_state.pipeline_run:
        run = st.session_state.pipeline_run
        if run.shortlist:
            n_ranked = len(run.shortlist.ranked_candidates)
            n_excl = len(run.shortlist.excluded_candidates)
            st.markdown(f"""
            <div class="card-accent" style="margin-top:1rem;">
              <div style="font-size:1rem; font-weight:700; color:#34d399; margin-bottom:8px;">├б┼ЊРђд Pipeline Complete!</div>
              <div style="display:flex; gap:1rem; flex-wrap:wrap;">
                <div class="stat-badge green">├б┼ЊРђю {n_ranked} ranked</div>
                <div class="stat-badge rose">├б┼А┬А {n_excl} excluded</div>
              </div>
            </div>
            """, unsafe_allow_html=True)
            if st.button("├░┼ИРђю┼а View Results ├бРђаРђЎ", type="primary"):
                st.session_state.page = "results"
                st.rerun()


def _render_step_tracker(step_status, placeholders, step_names):
    for step_num in sorted(placeholders.keys()):
        placeholder = placeholders[step_num]
        status = step_status[step_num]

        if status == "done":
            badge_cls = "step-badge done"
            icon = "├б┼ЊРђю"
            text_color = "#34d399"
            row_cls = "done"
        elif status == "running":
            badge_cls = "step-badge running"
            icon = "├б┼И┬│"
            text_color = "#ff80c7"
            row_cls = "running"
        elif status == "error":
            badge_cls = "step-badge error"
            icon = "├б┼ЊРђћ"
            text_color = "#fb7185"
            row_cls = ""
        else:
            badge_cls = "step-badge"
            icon = str(step_num)
            text_color = "#948a7c"
            row_cls = ""

        placeholder.markdown(
            f'<div class="step-row {row_cls}">'
            f'<span class="{badge_cls}">{icon}</span>'
            f'<span style="color:{text_color}; font-size:0.88rem; font-weight:{"600" if status in ("running","done") else "400"}">'
            f'{step_names[step_num]}</span></div>',
            unsafe_allow_html=True,
        )


# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
# Page 4: Results
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def page_results():
    run = st.session_state.pipeline_run
    if not run or not run.shortlist:
        st.warning("No results yet. Complete a pipeline run first.")
        return

    shortlist = run.shortlist
    rubric = st.session_state.frozen_rubric

    st.markdown(f"""
    <div class="hero-banner">
      <div class="hero-title">Selected shortlist - {shortlist.job_title}</div>
      <div class="hero-sub">Run ID: <code>{shortlist.run_id}</code> ├ѓ┬и Evidence-backed ranking complete.</div>
    </div>
    """, unsafe_allow_html=True)

    # ├бРђЮРѓг├бРђЮРѓг KPI Row ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    top = shortlist.ranked_candidates[0] if shortlist.ranked_candidates else None
    c1, c2, c3, c4, c5 = st.columns(5)
    with c1: st.metric("Submitted", shortlist.total_resumes_submitted)
    with c2: st.metric("Shortlisted", shortlist.shortlisted_count)
    with c3: st.metric("Ranked", len(shortlist.ranked_candidates))
    with c4: st.metric("Excluded", len(shortlist.excluded_candidates))
    with c5: st.metric("Top Score", f"{top.final_score:.2f}/10" if top else "├бРѓгРђЮ")

    st.markdown("---")

    # ├бРђЮРѓг├бРђЮРѓг Charts ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    if shortlist.ranked_candidates:
        col_chart, col_conf = st.columns([3, 1])

        with col_chart:
            st.markdown("## Score Distribution")
            scores = [c.final_score for c in shortlist.ranked_candidates]
            names = [c.name[:18] for c in shortlist.ranked_candidates]
            fig = go.Figure(go.Bar(
                x=names, y=scores,
                marker=dict(
                    color=scores,
                    colorscale=[[0, '#fb7185'], [0.5, '#fbbf24'], [1.0, '#34d399']],
                    cmin=0, cmax=10,
                    line=dict(width=0),
                ),
                hovertemplate="<b>%{x}</b><br>Score: %{y:.2f}/10<extra></extra>",
            ))
            fig.update_layout(
                paper_bgcolor="rgba(0,0,0,0)",
                plot_bgcolor="rgba(17,24,39,0.6)",
                font=dict(family="Inter", color="#4d463d", size=12),
                xaxis=dict(tickangle=-35, gridcolor="rgba(255,255,255,0.05)", showgrid=False),
                yaxis=dict(range=[0, 10.5], gridcolor="rgba(17,17,17,0.06)"),
                showlegend=False,
                height=300,
                margin=dict(l=0, r=0, t=10, b=80),
            )
            st.plotly_chart(fig, use_container_width=True)

        with col_conf:
            st.markdown("## Confidence")
            conf_counts = {"High": 0, "Medium": 0, "Low": 0}
            for c in shortlist.ranked_candidates:
                conf_counts[c.confidence] = conf_counts.get(c.confidence, 0) + 1
            fig2 = go.Figure(go.Pie(
                labels=list(conf_counts.keys()),
                values=list(conf_counts.values()),
                marker=dict(colors=["#34d399", "#fbbf24", "#fb7185"],
                            line=dict(color="#fffaf2", width=2)),
                hole=0.65,
                textinfo="percent",
                textfont=dict(size=11, color="#111111"),
            ))
            fig2.update_layout(
                paper_bgcolor="rgba(0,0,0,0)",
                font=dict(family="Inter", color="#4d463d"),
                height=220,
                margin=dict(l=0, r=0, t=10, b=10),
                legend=dict(font=dict(size=11), orientation="h", y=-0.1),
            )
            st.plotly_chart(fig2, use_container_width=True)

    st.markdown("---")

    # ├бРђЮРѓг├бРђЮРѓг Tabs ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
    all_tabs = ["├░┼И┬ЈРђа Ranked Candidates", "├░┼И┼А┬Ф Excluded", "├░┼ИРђюРђ╣ Rubric", "├░┼ИРђю┬Ц Export"]
    is_jsonl = st.session_state.get("is_jsonl_mode") and run.structured_scores
    if is_jsonl:
        all_tabs.append("├░┼ИРђю┼а Full Pool")

    tabs = st.tabs(all_tabs)

    with tabs[0]:
        if not shortlist.ranked_candidates:
            st.info("No candidates ranked ├бРѓгРђЮ all excluded or none shortlisted.")
        else:
            # Heatmap
            st.markdown("## Score Matrix ├бРѓгРђЮ Top 10")
            candidate_names = [c.name[:22] for c in shortlist.ranked_candidates[:10]]
            criteria_names = [c.criterion[:28] for c in rubric.weighted_criteria]
            score_matrix = []
            for cand in shortlist.ranked_candidates[:10]:
                score_map_h = {cs.criterion_id: cs.score for cs in cand.criterion_scores}
                row = [score_map_h.get(crit.id, 0) for crit in rubric.weighted_criteria]
                score_matrix.append(row)

            if score_matrix:
                fig_heat = go.Figure(go.Heatmap(
                    z=score_matrix, x=criteria_names, y=candidate_names,
                    colorscale=[[0,'#450a0a'], [0.35,'#78350f'], [0.7,'#065f46'], [1.0,'#34d399']],
                    zmin=0, zmax=10,
                    text=[[f"{v}" for v in row] for row in score_matrix],
                    texttemplate="%{text}",
                    textfont=dict(size=11, family="Inter"),
                    showscale=True,
                    colorbar=dict(
                        thickness=10, len=0.9,
                        tickfont=dict(size=10, color="#4d463d"),
                        outlinewidth=0,
                    ),
                ))
                fig_heat.update_layout(
                    paper_bgcolor="rgba(0,0,0,0)",
                    plot_bgcolor="rgba(0,0,0,0)",
                    font=dict(family="Inter", color="#4d463d", size=11),
                    height=max(220, len(candidate_names) * 40 + 80),
                    margin=dict(l=0, r=0, t=20, b=0),
                )
                st.plotly_chart(fig_heat, use_container_width=True)

            st.markdown("---")
            for candidate in shortlist.ranked_candidates:
                _render_candidate_card(candidate, rubric)

    with tabs[1]:
        # ├бРђЮРѓг├бРђЮРѓг Honeypot / Excluded breakdown ├бРѓгРђЮ aggregate view, never a raw list of 18K rows ├бРђЮРѓг├бРђЮРѓг
        all_sc = run.structured_scores if (is_jsonl and run.structured_scores) else []
        hp_scores = [s for s in all_sc if s.is_honeypot]
        n_excl_hard = sum(1 for s in all_sc if s.is_honeypot and (
            any(r.startswith('CHK_A') or r.startswith('CHK_B') for r in s.honeypot_reasons)
        ))
        n_excl_soft = len(hp_scores) - n_excl_hard

        # Human-readable check name map
        CHECK_LABELS = {
            "CHK_A_salary_inversion":          "Salary range inverted (min > max)",
            "CHK_B_github_inactive_paradox":   "GitHub score high but account inactive 2+ years",
            "CHK_1_skill_duration_impossible": "Skill duration exceeds entire career length",
            "CHK_2_career_yoe_mismatch":       "Total career months >> declared years of experience",
            "CHK_3_expert_zero_endorsements":  "3+ 'expert' skills with zero endorsements & zero duration",
            "CHK_4_education_date_inversion":  "Education end year before start year",
            "CHK_6_yoe_exceeds_career_start":  "Declared YoE impossible given earliest career start year",
            "CHK_C_profile_completeness_paradox": "100% profile completeness with zero network activity",
            "CHK_D_assessment_zero_endorsement":  "Perfect assessment score + zero endorsements anywhere",
            "CHK_E_career_gap_impossibility":  "Documented career months < half of declared YoE",
            "CHK_F_new_signup_high_yoe":       "New account (<30 days) claiming 5+ years experience",
            "CHK_G_expert_no_assessments":     "5+ expert skills but zero platform assessments taken",
        }

        if hp_scores:
            st.markdown(f"""
            <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1.5rem;">
              <div class="stat-badge rose">&#x26A1; {len(hp_scores):,} total excluded</div>
              <div class="stat-badge rose">&#x1F534; {n_excl_hard:,} hard-signal (single check)</div>
              <div class="stat-badge" style="background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.2);color:#fbbf24;">
                &#x26A0; {n_excl_soft:,} soft-signal (2+ checks)
              </div>
            </div>
            """, unsafe_allow_html=True)

            # Breakdown by trigger type
            from collections import Counter
            reason_counter = Counter()
            for s in hp_scores:
                for r in s.honeypot_reasons:
                    reason_counter[r] += 1

            st.markdown("#### Exclusion Breakdown by Signal")
            breakdown_rows = []
            for chk, count in reason_counter.most_common():
                label = CHECK_LABELS.get(chk, chk)
                tier = "Hard (1-hit)" if chk.startswith(("CHK_A", "CHK_B")) else "Soft (2-hit)"
                breakdown_rows.append({"Signal": chk, "Reason": label, "Tier": tier, "Count": count})

            breakdown_df = pd.DataFrame(breakdown_rows)
            st.dataframe(breakdown_df, use_container_width=True, hide_index=True)

            st.markdown("---")
            st.markdown("#### Sample Excluded Candidates (first 15)")
            st.caption("Showing 15 of {:,} excluded ├бРѓгРђЮ use Complete Order view to see all in rank context.".format(len(hp_scores)))
            for s in hp_scores[:15]:
                reasons_human = [CHECK_LABELS.get(r, r) for r in s.honeypot_reasons]
                reason_str = " | ".join(reasons_human[:2])
                st.markdown(f"""
                <div style="background:rgba(251,113,133,0.06); border:1px solid rgba(251,113,133,0.2);
                border-radius:8px; padding:10px 14px; margin-bottom:8px; display:flex; align-items:center; gap:1rem;">
                  <span style="color:#fb7185; font-size:1.1rem;">&#x1F6AB;</span>
                  <div>
                    <div style="font-weight:600; color:#111111;">{s.current_title} &middot; {s.location}</div>
                    <div style="font-size:0.78rem; color:#fb7185; margin-top:2px;">{reason_str}</div>
                    <div style="font-size:0.75rem; color:#6b6258;">Score (before exclusion): {s.composite_score:.3f}</div>
                  </div>
                </div>
                """, unsafe_allow_html=True)
        else:
            st.success("No anomalous profiles detected in this run.")

    with tabs[2]:
        if rubric:
            col_r1, col_r2, col_r3 = st.columns(3)
            with col_r1:
                st.markdown(f"**Role:** {rubric.job_title}")
            with col_r2:
                st.markdown(f"**Frozen:** `{rubric.frozen_at}`")
            with col_r3:
                st.markdown(f"**Bonus:** `{rubric.bonus_sensitivity}`")

            rows = [{"ID": c.id, "Criterion": c.criterion, "Category": c.category,
                     "Weight": f"{c.weight:.3f}", "Rationale": c.rationale}
                    for c in rubric.weighted_criteria]
            st.dataframe(pd.DataFrame(rows), use_container_width=True)

            if rubric.hard_gates:
                st.markdown("**Hard Gates:**")
                for g in rubric.hard_gates:
                    st.markdown(f"- {'├░┼ИРђЮ┬┤ Strict' if g.strict else '├░┼И┼И┬А Flexible'}: {g.criterion}")

    with tabs[3]:
        run_dir = run.run_dir
        csv_path = run_dir / "ranked_shortlist.csv"
        html_path = run_dir / "run_report.html"
        rubric_path = run_dir / "rubric.json"

        st.markdown("### ├░┼ИРђю┬Ц Download Artifacts")
        col_dl1, col_dl2, col_dl3 = st.columns(3)
        with col_dl1:
            if csv_path.exists():
                st.download_button(
                    "├░┼ИРђю┼а Download CSV", data=csv_path.read_bytes(),
                    file_name=f"ranked_{shortlist.run_id}.csv", mime="text/csv",
                )
                st.caption("Submission-ready ranked list")
        with col_dl2:
            if html_path.exists():
                st.download_button(
                    "├░┼ИРђюРђъ Download HTML Report", data=html_path.read_bytes(),
                    file_name=f"report_{shortlist.run_id}.html", mime="text/html",
                )
                st.caption("Self-contained visual report")
        with col_dl3:
            if rubric_path.exists():
                st.download_button(
                    "├░┼ИРђюРђ╣ Download Rubric JSON", data=rubric_path.read_bytes(),
                    file_name=f"rubric_{shortlist.run_id}.json", mime="application/json",
                )
                st.caption("Audit trail for this run")

        st.markdown(f"<div style='font-size:0.78rem; color:#948a7c; margin-top:1rem;'>Output directory: <code>{run_dir}</code></div>", unsafe_allow_html=True)

    if is_jsonl and len(tabs) > 4:
        with tabs[4]:
            st.markdown("## Complete Order ├бРѓгРђЮ Full Ranking View")
            st.markdown("""
            <div style="font-size:0.83rem; color:#4d463d; margin-bottom:1.2rem;">
              All candidates shown in a single unified rank order by composite score.
              <span style="color:#34d399; font-weight:600;">&#x2588; Shortlisted</span> = in submission &nbsp;|&nbsp;
              <span style="color:#fb7185; font-weight:600;">&#x2588; Excluded</span> = anomalous profile detected &nbsp;|&nbsp;
              <span style="color:#60a5fa; font-weight:600;">&#x2588; Candidate</span> = clean, ranked but outside top 100
            </div>
            """, unsafe_allow_html=True)

            all_scores = run.structured_scores
            total_pool = len(all_scores)
            n_honeypots = sum(1 for s in all_scores if s.is_honeypot)
            n_clean     = total_pool - n_honeypots

            # Summary metrics
            c1, c2, c3, c4, c5 = st.columns(5)
            with c1: st.metric("Total Pool", f"{total_pool:,}")
            with c2: st.metric("Shortlisted", 100)
            with c3: st.metric("Excluded", f"{n_honeypots:,}")
            with c4: st.metric("Remaining Clean", f"{n_clean - 100:,}")
            with c5:
                top_s = next((s for s in all_scores if not s.is_honeypot), None)
                st.metric("Top Score", f"{top_s.composite_score:.4f}" if top_s else "N/A")

            st.markdown("---")

            # Controls
            col_n, col_search = st.columns([1, 2])
            with col_n:
                view_n = st.slider(
                    "View top N positions", min_value=10, max_value=300,
                    value=30, step=10, key="complete_order_n",
                    help="Shows the top N candidates in rank order, including any excluded profiles that would have appeared in this range."
                )
            with col_search:
                search_q = st.text_input(
                    "Filter by title / location", key="complete_order_search",
                    placeholder="e.g. NLP Engineer, Noida..."
                )

            # Build unified rank: sort ALL by composite_score (ignoring is_honeypot),
            # take top view_n, display each with status badge.
            # We limit to top-2000 for perf, then slice view_n.
            CHECK_LABELS_BRIEF = {
                "CHK_A_salary_inversion":          "Salary range inverted",
                "CHK_B_github_inactive_paradox":   "GitHub + inactive paradox",
                "CHK_1_skill_duration_impossible": "Skill older than career",
                "CHK_2_career_yoe_mismatch":       "Career months >> YoE",
                "CHK_3_expert_zero_endorsements":  "Expert skills with zero proof",
                "CHK_4_education_date_inversion":  "Education dates inverted",
                "CHK_6_yoe_exceeds_career_start":  "YoE exceeds career start",
                "CHK_C_profile_completeness_paradox": "Perfect profile, zero network",
                "CHK_D_assessment_zero_endorsement":  "Perfect score, zero endorsements",
                "CHK_E_career_gap_impossibility":  "Career gap vs claimed YoE",
                "CHK_F_new_signup_high_yoe":       "New account, high YoE claim",
                "CHK_G_expert_no_assessments":     "Expert skills, no assessments",
            }

            # Build submission ID set for fast lookup
            submission_ids = set()
            sub_csv = Path("submission.csv")
            if sub_csv.exists():
                import csv as _csv
                with open(sub_csv, encoding="utf-8") as _f:
                    for row in _csv.DictReader(_f):
                        submission_ids.add(row["candidate_id"])

            # Sort ALL scores by raw composite (not honeypot-penalised order)
            unified = sorted(all_scores, key=lambda s: -s.composite_score)

            # Filter by search if set
            if search_q:
                q = search_q.lower()
                unified = [s for s in unified if q in s.current_title.lower() or q in s.location.lower() or q in s.name.lower()]

            display_list = unified[:view_n]

            for global_pos, s in enumerate(display_list, start=1):
                is_sub    = s.candidate_id in submission_ids and not s.is_honeypot
                is_hp     = s.is_honeypot
                # Badge colours
                if is_sub:
                    badge_bg   = "rgba(52,211,153,0.10)"
                    badge_bdr  = "rgba(52,211,153,0.30)"
                    badge_col  = "#34d399"
                    badge_text = "SHORTLISTED"
                    badge_icon = "&#x2714;"
                elif is_hp:
                    badge_bg   = "rgba(251,113,133,0.10)"
                    badge_bdr  = "rgba(251,113,133,0.30)"
                    badge_col  = "#fb7185"
                    badge_text = "EXCLUDED"
                    badge_icon = "&#x1F6AB;"
                else:
                    badge_bg   = "rgba(96,165,250,0.07)"
                    badge_bdr  = "rgba(96,165,250,0.20)"
                    badge_col  = "#60a5fa"
                    badge_text = "CANDIDATE"
                    badge_icon = "&#x1F464;"

                # Exclusion reason (brief)
                excl_note = ""
                if is_hp and s.honeypot_reasons:
                    reasons_brief = [CHECK_LABELS_BRIEF.get(r, r) for r in s.honeypot_reasons[:2]]
                    excl_note = f"<span style='color:#fb7185; font-size:0.74rem;'> &mdash; {' | '.join(reasons_brief)}</span>"

                # Rank label
                rank_label = f"#{s.rank}" if s.rank else f"#{global_pos}"

                st.markdown(f"""
                <div style="background:{badge_bg}; border:1px solid {badge_bdr}; border-radius:10px;
                padding:10px 16px; margin-bottom:8px; display:flex; align-items:center; gap:1rem;">
                  <div style="min-width:2.4rem; text-align:center; font-weight:700;
                  color:{badge_col}; font-size:0.85rem;">{rank_label}</div>
                  <div style="flex:1; min-width:0;">
                    <div style="font-weight:600; color:#111111; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                      {s.current_title} &middot; <span style='color:#4d463d;'>{s.location}</span>
                      {excl_note}
                    </div>
                    <div style="font-size:0.78rem; color:#6b6258; margin-top:2px;">
                      {s.years_of_experience:.1f} yrs &nbsp;&middot;&nbsp;
                      {s.current_company} &nbsp;&middot;&nbsp;
                      Score: <span style='color:{badge_col}; font-weight:600;'>{s.composite_score:.4f}</span>
                    </div>
                  </div>
                  <div style="min-width:fit-content; background:{badge_bdr}; color:{badge_col};
                  font-size:0.72rem; font-weight:700; padding:3px 10px; border-radius:20px;
                  letter-spacing:0.04em;">{badge_icon} {badge_text}</div>
                </div>
                """, unsafe_allow_html=True)

            if not display_list:
                st.info("No candidates match the current filter.")

            st.markdown("---")
            st.markdown("### Export Submission CSV")
            if st.button("Generate & Download submission.csv", key="btn_export_pool_csv"):
                import io, csv as _csv2
                clean = [s for s in all_scores if not s.is_honeypot][:100]
                csv_buf = io.StringIO()
                w = _csv2.writer(csv_buf)
                w.writerow(["candidate_id", "rank", "score", "reasoning"])
                for i, s in enumerate(clean):
                    w.writerow([s.candidate_id, i + 1, round(s.composite_score, 4), s.reasoning])
                st.download_button(
                    "Download submission.csv",
                    data=csv_buf.getvalue().encode("utf-8"),
                    file_name=f"submission_{run.run_id}.csv",
                    mime="text/csv",
                )

    # New Run
    st.markdown("---")
    if st.button("├░┼ИРђЮРђъ Start New Evaluation Run"):
        for key in ["jd_parse_result", "frozen_rubric", "pipeline_run",
                    "jd_file_path", "resume_file_paths", "progress_updates",
                    "run_complete", "run_error",
                    "is_jsonl_mode", "jsonl_file_path", "jsonl_llm_top_n"]:
            st.session_state[key] = None if key not in ["resume_file_paths", "progress_updates"] else []
        st.session_state.is_jsonl_mode = False
        st.session_state.jsonl_llm_top_n = 50
        st.session_state.page = "upload"
        st.rerun()


# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
# Candidate Card
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def _render_candidate_card(candidate: CandidateRecord, rubric: FrozenRubric):
    score = candidate.final_score
    sc = score_color(score)
    conf = candidate.confidence
    conf_color = {"High": "#34d399", "Medium": "#fbbf24", "Low": "#fb7185"}.get(conf, "#4d463d")

    flag_html = ""
    for f in candidate.red_flags:
        cls = f"flag-{f.severity}"
        flag_html += f'<span class="flag-chip {cls}">{f.type}</span> '

    with st.expander(
        f"#{candidate.rank}  {candidate.name}  ├бРѓгРђЮ  {score:.2f}/10  ({conf} confidence)",
        expanded=(candidate.rank == 1)
    ):
        col_scores, col_sidebar = st.columns([3, 1])

        with col_scores:
            if flag_html:
                st.markdown(f"<div style='margin-bottom:10px;'>{flag_html}</div>", unsafe_allow_html=True)

            st.markdown("#### ├░┼ИРђюРђ╣ Criterion Scores")
            score_map = {cs.criterion_id: cs for cs in candidate.criterion_scores}

            for crit in rubric.weighted_criteria:
                cs = score_map.get(crit.id)
                if cs:
                    bar_w = int(cs.score / 10 * 100)
                    bar_color = score_color(cs.score)
                    verified_icon = "├б┼ЊРђд" if cs.evidence_verified else "├б┼А┬а├»┬И┬Ј"

                    st.markdown(
                        f"<div style='display:flex; align-items:center; justify-content:space-between; margin-bottom:4px;'>"
                        f"<span style='font-size:0.88rem; font-weight:600; color:#111111;'>{crit.criterion}</span>"
                        f"<span style='font-size:0.78rem; color:#948a7c;'>w={crit.weight:.2f}</span>"
                        f"</div>"
                        f"<div style='display:flex; align-items:center; gap:10px; margin-bottom:2px;'>"
                        f"<div class='score-bar-bg' style='flex:1;'>"
                        f"<div class='score-bar-fill' style='width:{bar_w}%; background:linear-gradient(90deg,{bar_color}88,{bar_color});'></div>"
                        f"</div>"
                        f"<span style='font-size:0.88rem; font-weight:700; color:{bar_color}; min-width:42px; text-align:right;'>{cs.score}/10</span>"
                        f"<span style='font-size:0.82rem;'>{verified_icon}</span>"
                        f"</div>",
                        unsafe_allow_html=True,
                    )

                    if cs.evidence_quote != "NO_EVIDENCE_FOUND" and cs.evidence_quote:
                        st.markdown(
                            f'<div class="evidence-quote">├░┼ИРђю┼й {cs.evidence_quote}</div>',
                            unsafe_allow_html=True,
                        )
                    else:
                        st.markdown("<div style='font-size:0.78rem; color:#948a7c; margin-bottom:4px;'>├░┼ИРђю┼й No evidence found</div>", unsafe_allow_html=True)

                    if cs.answer:
                        st.caption(f"├░┼ИРђЎ┬г {cs.answer}")

                    st.markdown("<div style='height:10px;'></div>", unsafe_allow_html=True)

        with col_sidebar:
            st.markdown(f"""
            <div class="card" style="text-align:center; padding:1rem;">
              <div style="font-size:2rem; font-weight:800; color:{sc}; line-height:1;">{score:.2f}</div>
              <div style="font-size:0.72rem; color:#948a7c; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:12px;">Final Score / 10</div>
              <div style="display:flex; flex-direction:column; gap:6px;">
                <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                  <span style="color:#4d463d;">Base</span>
                  <span style="color:#111111; font-weight:600;">{candidate.base_score:.2f}</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                  <span style="color:#4d463d;">Bonus</span>
                  <span style="color:#34d399; font-weight:600;">+{candidate.bonus_applied:.2f}</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.8rem;">
                  <span style="color:#4d463d;">Embed Sim</span>
                  <span style="color:#111111; font-weight:600;">{candidate.embedding_score:.2f}</span>
                </div>
                <hr style="border-color:rgba(255,128,199,0.15); margin:6px 0;">
                <div style="display:flex; justify-content:space-between; font-size:0.8rem; align-items:center;">
                  <span style="color:#4d463d;">Confidence</span>
                  <span style="font-size:0.75rem; font-weight:700; color:{conf_color}; background:rgba({','.join(str(int(conf_color[i:i+2],16)) for i in (1,3,5))},0.15); padding:2px 8px; border-radius:100px;">{conf}</span>
                </div>
              </div>
            </div>
            """, unsafe_allow_html=True)

            if candidate.open_signals:
                st.markdown("#### ├░┼И┼њ┼И Open Signals")
                for sig in candidate.open_signals:
                    st.markdown(
                        f"<div style='background:rgba(255,128,199,0.08); border:1px solid rgba(255,128,199,0.2); "
                        f"border-radius:6px; padding:7px 10px; margin-bottom:4px; font-size:0.8rem;'>"
                        f"├б┬Г┬љ {sig.signal}<br>"
                        f"<span style='color:#111111; font-size:0.74rem;'>strength: {sig.strength:.2f}</span></div>",
                        unsafe_allow_html=True,
                    )

            if candidate.gate_results:
                st.markdown("#### ├░┼ИРђЮРђЎ Gates")
                for gr in candidate.gate_results:
                    icon = "├б┼ЊРђд" if gr.passed else "├б┬Ю┼њ"
                    st.markdown(f"<div style='font-size:0.8rem; margin-bottom:2px;'>{icon} {gr.criterion[:38]}{'├бРѓг┬д' if len(gr.criterion)>38 else ''}</div>", unsafe_allow_html=True)


# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
# Main Router
# ├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг├бРђЮРѓг
def main():
    render_sidebar()
    page = st.session_state.page
    if page == "upload":
        page_upload()
    elif page == "calibrate":
        page_calibrate()
    elif page == "processing":
        page_processing()
    elif page == "results":
        page_results()
    else:
        st.session_state.page = "upload"
        st.rerun()


if __name__ == "__main__":
    main()









