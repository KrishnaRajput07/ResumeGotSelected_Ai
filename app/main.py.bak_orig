<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

  /* ├бРђЮРѓг├бРђЮРѓг Root vars ├бРђЮРѓг├бРђЮРѓг */
  :root {
    --bg-base:     #fffaf2;
    --bg-surface:  #fffaf2;
    --bg-elevated: #fff4df;
    --bg-glass:    rgba(255,255,255,0.78);
    --border-subtle: rgba(255,128,199,0.18);
    --border-strong: rgba(255,128,199,0.40);
    --violet-400:  #ff80c7;
    --violet-500:  #ff80c7;
    --violet-600:  #111111;
    --violet-700:  #000000;
    --teal-400:    #ffbf00;
    --teal-500:    #ffbf00;
    --rose-400:    #fb7185;
    --amber-400:   #fbbf24;
    --green-400:   #34d399;
    --text-primary: #111111;
    --text-secondary: #4d463d;
    --text-muted: #948a7c;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Global resets ├бРђЮРѓг├бРђЮРѓг */
  * { box-sizing: border-box; }

  html, body, [data-testid="stAppViewContainer"] {
    background: var(--bg-base) !important;
    color: var(--text-primary) !important;
    font-family: 'Inter', -apple-system, sans-serif !important;
    font-size: 14px;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Gradient mesh background ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stAppViewContainer"]::before {
    content: '';
    position: fixed;
    top: -30%;
    left: -20%;
    width: 60%;
    height: 60%;
    background: radial-gradient(ellipse at center, rgba(255,128,199,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  [data-testid="stAppViewContainer"]::after {
    content: '';
    position: fixed;
    bottom: -20%;
    right: -10%;
    width: 50%;
    height: 50%;
    background: radial-gradient(ellipse at center, rgba(255,191,0,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Main content ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stMain"] { position: relative; z-index: 1; }
  .main .block-container {
    padding: 1.5rem 2rem 3rem 2rem !important;
    max-width: 1400px !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Sidebar ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stSidebar"] {
    background: linear-gradient(180deg, #fffaf2 0%, #fffaf2 100%) !important;
    border-right: 1px solid var(--border-subtle) !important;
  }
  [data-testid="stSidebar"] > div { padding: 0 !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Header strip ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stHeader"] { background: transparent !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Typography ├бРђЮРѓг├бРђЮРѓг */
  h1 {
    font-size: 2rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.04em !important;
    line-height: 1.1 !important;
    background: linear-gradient(135deg, #ff80c7 0%, #ff80c7 40%, #ffbf00 100%);
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
    margin-bottom: 0.25rem !important;
  }
  h2 {
    font-size: 1.15rem !important;
    font-weight: 700 !important;
    color: var(--violet-400) !important;
    letter-spacing: -0.02em !important;
    margin-top: 1.75rem !important;
  }
  h3 {
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: #ff80c7 !important;
  }
  p, li { color: var(--text-secondary) !important; line-height: 1.65 !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Glass cards ├бРђЮРѓг├бРђЮРѓг */
  .card {
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 0 24px rgba(255,128,199,0.08);
  }
  .card-accent {
    background: linear-gradient(135deg, rgba(255,128,199,0.08) 0%, rgba(255,191,0,0.04) 100%);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Hero banner ├бРђЮРѓг├бРђЮРѓг */
  .hero-banner {
    background: linear-gradient(135deg, rgba(255,128,199,0.15) 0%, rgba(255,191,0,0.08) 100%);
    border: 1px solid rgba(255,128,199,0.25);
    border-radius: var(--radius-xl);
    padding: 2rem 2.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero-banner::before {
    content: '├б┼Њ┬д';
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 6rem;
    opacity: 0.05;
    color: var(--violet-400);
  }
  .hero-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #ff80c7 0%, #ff80c7 50%, #ffbf00 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 0.5rem 0;
  }
  .hero-sub {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin: 0;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Metric tiles ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="metric-container"] {
    background: var(--bg-glass) !important;
    border: 1px solid var(--border-subtle) !important;
    border-radius: var(--radius-md) !important;
    padding: 1rem 1.25rem !important;
    transition: all 0.2s ease !important;
  }
  [data-testid="metric-container"]:hover {
    border-color: var(--border-strong) !important;
    box-shadow: 0 4px 20px rgba(255,128,199,0.12) !important;
  }
  [data-testid="stMetricValue"] {
    font-size: 1.6rem !important;
    font-weight: 800 !important;
    color: var(--text-primary) !important;
  }
  [data-testid="stMetricLabel"] {
    font-size: 0.75rem !important;
    color: var(--text-secondary) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    font-weight: 500 !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Stat badges ├бРђЮРѓг├бРђЮРѓг */
  .stat-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,128,199,0.12);
    border: 1px solid rgba(255,128,199,0.25);
    border-radius: 100px;
    padding: 4px 12px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--violet-400);
  }
  .stat-badge.teal {
    background: rgba(255,191,0,0.1);
    border-color: rgba(255,191,0,0.25);
    color: var(--teal-400);
  }
  .stat-badge.rose {
    background: rgba(251,113,133,0.1);
    border-color: rgba(251,113,133,0.25);
    color: var(--rose-400);
  }
  .stat-badge.amber {
    background: rgba(251,191,36,0.1);
    border-color: rgba(251,191,36,0.25);
    color: var(--amber-400);
  }
  .stat-badge.green {
    background: rgba(52,211,153,0.1);
    border-color: rgba(52,211,153,0.25);
    color: var(--green-400);
  }

  /* ├бРђЮРѓг├бРђЮРѓг Step indicator ├бРђЮРѓг├бРђЮРѓг */
  .step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--violet-600), var(--violet-700));
    color: #fff;
    border-radius: 50%;
    width: 26px; height: 26px;
    font-weight: 700; font-size: 0.8rem;
    margin-right: 10px;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(17,17,17,0.4);
  }
  .step-badge.done {
    background: linear-gradient(135deg, var(--teal-500), #0d9488);
    box-shadow: 0 2px 8px rgba(255,191,0,0.4);
  }
  .step-badge.running {
    background: linear-gradient(135deg, var(--violet-500), var(--violet-600));
    animation: pulse-ring 1.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
  }
  .step-badge.error {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    box-shadow: 0 2px 8px rgba(239,68,68,0.4);
  }
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(255,128,199,0.5); }
    70% { box-shadow: 0 0 0 8px rgba(255,128,199,0); }
    100% { box-shadow: 0 0 0 0 rgba(255,128,199,0); }
  }
  .step-row {
    display: flex;
    align-items: center;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    margin-bottom: 4px;
    transition: background 0.2s;
  }
  .step-row.running { background: rgba(255,128,199,0.08); }
  .step-row.done { background: rgba(255,191,0,0.06); }

  /* ├бРђЮРѓг├бРђЮРѓг Score pills ├бРђЮРѓг├бРђЮРѓг */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .pill-high { background: rgba(52,211,153,0.15); color: #34d399; border: 1px solid rgba(52,211,153,0.3); }
  .pill-mid  { background: rgba(251,191,36,0.15); color: #fbbf24; border: 1px solid rgba(251,191,36,0.3); }
  .pill-low  { background: rgba(251,113,133,0.15); color: #fb7185; border: 1px solid rgba(251,113,133,0.3); }
  .pill-violet { background: rgba(255,128,199,0.15); color: #ff80c7; border: 1px solid rgba(255,128,199,0.3); }

  /* ├бРђЮРѓг├бРђЮРѓг Candidate card ├бРђЮРѓг├бРђЮРѓг */
  .cand-card {
    background: var(--bg-glass);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    margin-bottom: 0.5rem;
    transition: all 0.2s ease;
    cursor: pointer;
  }
  .cand-card:hover {
    border-color: var(--border-strong);
    background: rgba(255,128,199,0.06);
    transform: translateX(2px);
  }
  .cand-rank {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--violet-500);
    min-width: 2rem;
    line-height: 1;
  }
  .cand-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .cand-title {
    font-size: 0.82rem;
    color: var(--text-secondary);
    margin-top: 2px;
  }
  .score-bar-bg {
    background: rgba(17,17,17,0.06);
    border-radius: 100px;
    height: 6px;
    margin-top: 6px;
    overflow: hidden;
  }
  .score-bar-fill {
    height: 100%;
    border-radius: 100px;
    background: linear-gradient(90deg, var(--violet-600), var(--teal-400));
    transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ├бРђЮРѓг├бРђЮРѓг Nav items in sidebar ├бРђЮРѓг├бРђЮРѓг */
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    border-radius: var(--radius-sm);
    margin: 2px 8px;
    cursor: pointer;
    transition: all 0.15s ease;
    font-weight: 500;
    font-size: 0.88rem;
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid transparent;
  }
  .nav-item:hover { background: rgba(255,128,199,0.08); color: var(--text-primary); }
  .nav-item.active {
    background: rgba(255,128,199,0.16);
    color: var(--violet-400);
    border-color: rgba(255,128,199,0.25);
    font-weight: 600;
  }
  .nav-icon { font-size: 1rem; width: 20px; text-align: center; }
  .nav-label { flex: 1; }
  .nav-dot {
    width: 6px; height: 6px;
    background: var(--teal-400);
    border-radius: 50%;
    animation: blink 1.5s ease-in-out infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .nav-lock { color: var(--text-muted); font-size: 0.7rem; }

  /* ├бРђЮРѓг├бРђЮРѓг Evidence quote ├бРђЮРѓг├бРђЮРѓг */
  .evidence-quote {
    background: rgba(255,128,199,0.06);
    border-left: 3px solid var(--violet-500);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 8px 12px;
    margin: 6px 0;
    font-size: 0.82rem;
    color: var(--violet-400);
    font-style: italic;
    line-height: 1.5;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Flag chips ├бРђЮРѓг├бРђЮРѓг */
  .flag-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 100px;
    font-size: 0.74rem;
    font-weight: 600;
    margin: 2px;
  }
  .flag-info    { background: rgba(96,165,250,0.12); color: #60a5fa; border: 1px solid rgba(96,165,250,0.25); }
  .flag-review  { background: rgba(251,191,36,0.12); color: #fbbf24; border: 1px solid rgba(251,191,36,0.25); }
  .flag-concern { background: rgba(251,113,133,0.12); color: #fb7185; border: 1px solid rgba(251,113,133,0.25); }

  /* ├бРђЮРѓг├бРђЮРѓг Buttons ├бРђЮРѓг├бРђЮРѓг */
  .stButton > button {
    background: linear-gradient(135deg, var(--violet-600) 0%, var(--violet-700) 100%) !important;
    color: white !important;
    border: none !important;
    border-radius: var(--radius-sm) !important;
    font-weight: 600 !important;
    font-size: 0.88rem !important;
    padding: 0.55rem 1.5rem !important;
    transition: all 0.2s ease !important;
    letter-spacing: 0.01em !important;
    box-shadow: 0 2px 12px rgba(17,17,17,0.3) !important;
  }
  .stButton > button:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 20px rgba(17,17,17,0.45) !important;
  }
  .stButton > button:active { transform: translateY(0) !important; }
  .stButton > button[disabled] {
    background: rgba(17,17,17,0.06) !important;
    color: var(--text-muted) !important;
    box-shadow: none !important;
    transform: none !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Primary CTA button ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stButton"] button[kind="primary"] {
    background: linear-gradient(135deg, var(--teal-500) 0%, var(--violet-600) 100%) !important;
    box-shadow: 0 3px 16px rgba(255,191,0,0.35) !important;
    padding: 0.65rem 2rem !important;
    font-size: 0.92rem !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Tabs ├бРђЮРѓг├бРђЮРѓг */
  .stTabs [data-baseweb="tab-list"] {
    background: transparent !important;
    border-bottom: 1px solid var(--border-subtle) !important;
    gap: 0 !important;
  }
  .stTabs [data-baseweb="tab"] {
    background: transparent !important;
    color: var(--text-secondary) !important;
    font-weight: 500 !important;
    font-size: 0.88rem !important;
    padding: 0.6rem 1.25rem !important;
    border-bottom: 2px solid transparent !important;
    transition: all 0.2s !important;
    border-radius: 0 !important;
  }
  .stTabs [data-baseweb="tab"]:hover { color: var(--text-primary) !important; }
  .stTabs [aria-selected="true"] {
    color: var(--violet-400) !important;
    border-bottom-color: var(--violet-500) !important;
    font-weight: 600 !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Slider ├бРђЮРѓг├бРђЮРѓг */
  .stSlider > div > div > div { background: var(--violet-600) !important; }
  .stSlider [data-testid="stTickBar"] > div { background: rgba(255,128,199,0.3) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Toggle ├бРђЮРѓг├бРђЮРѓг */
  .stToggle > label { color: var(--text-secondary) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Radio ├бРђЮРѓг├бРђЮРѓг */
  .stRadio label { color: var(--text-secondary) !important; font-size: 0.88rem !important; }
  .stRadio [aria-checked="true"] + div { color: var(--violet-400) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг File uploader ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stFileUploader"] {
    background: var(--bg-glass) !important;
    border: 2px dashed rgba(255,128,199,0.3) !important;
    border-radius: var(--radius-lg) !important;
    transition: all 0.2s ease !important;
  }
  [data-testid="stFileUploader"]:hover {
    border-color: rgba(255,128,199,0.6) !important;
    background: rgba(255,128,199,0.04) !important;
  }
  [data-testid="stFileUploaderDropzoneInstructions"] { color: var(--text-secondary) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Progress bar ├бРђЮРѓг├бРђЮРѓг */
  .stProgress > div > div > div {
    background: linear-gradient(90deg, var(--violet-600), var(--teal-400)) !important;
    border-radius: 100px !important;
  }
  .stProgress > div > div { background: rgba(17,17,17,0.06) !important; border-radius: 100px !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Expander ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stExpander"] {
    background: var(--bg-glass) !important;
    border: 1px solid var(--border-subtle) !important;
    border-radius: var(--radius-md) !important;
    margin-bottom: 6px !important;
    overflow: hidden !important;
  }
  [data-testid="stExpander"]:hover { border-color: var(--border-strong) !important; }
  [data-testid="stExpander"] summary {
    color: var(--text-primary) !important;
    font-weight: 500 !important;
    padding: 0.75rem 1rem !important;
  }
  [data-testid="stExpander"] summary:hover { background: rgba(255,128,199,0.04) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Text area, inputs ├бРђЮРѓг├бРђЮРѓг */
  .stTextArea textarea, .stTextInput input {
    background: var(--bg-elevated) !important;
    border: 1px solid var(--border-subtle) !important;
    border-radius: var(--radius-sm) !important;
    color: var(--text-primary) !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.82rem !important;
  }
  .stTextArea textarea:focus, .stTextInput input:focus {
    border-color: var(--violet-500) !important;
    box-shadow: 0 0 0 3px rgba(255,128,199,0.15) !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Selectbox ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stSelectbox"] > div > div {
    background: var(--bg-elevated) !important;
    border: 1px solid var(--border-subtle) !important;
    border-radius: var(--radius-sm) !important;
    color: var(--text-primary) !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг DataFrames ├бРђЮРѓг├бРђЮРѓг */
  .stDataFrame { border: 1px solid var(--border-subtle) !important; border-radius: var(--radius-md) !important; overflow: hidden !important; }
  .stDataFrame th { background: var(--bg-elevated) !important; color: var(--violet-400) !important; font-weight: 600 !important; font-size: 0.78rem !important; text-transform: uppercase !important; letter-spacing: 0.05em !important; }
  .stDataFrame td { background: var(--bg-surface) !important; color: var(--text-secondary) !important; font-size: 0.83rem !important; }
  .stDataFrame tr:hover td { background: rgba(255,128,199,0.06) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Alert / info boxes ├бРђЮРѓг├бРђЮРѓг */
  [data-testid="stAlert"] {
    border-radius: var(--radius-md) !important;
    border-width: 1px !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Divider ├бРђЮРѓг├бРђЮРѓг */
  hr { border-color: var(--border-subtle) !important; margin: 1.5rem 0 !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Code ├бРђЮРѓг├бРђЮРѓг */
  code {
    background: rgba(255,128,199,0.12) !important;
    color: var(--violet-400) !important;
    border-radius: 4px !important;
    padding: 1px 6px !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 0.82em !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Sidebar nav buttons override ├бРђЮРѓг├бРђЮРѓг */
  .sidebar-nav .stButton > button {
    background: transparent !important;
    border: 1px solid transparent !important;
    border-radius: var(--radius-sm) !important;
    color: var(--text-secondary) !important;
    font-weight: 500 !important;
    font-size: 0.88rem !important;
    text-align: left !important;
    justify-content: flex-start !important;
    padding: 0.6rem 1rem !important;
    box-shadow: none !important;
    width: 100% !important;
    transition: all 0.15s ease !important;
  }
  .sidebar-nav .stButton > button:hover {
    background: rgba(255,128,199,0.1) !important;
    color: var(--text-primary) !important;
    transform: none !important;
    box-shadow: none !important;
  }
  .sidebar-nav-active .stButton > button {
    background: rgba(255,128,199,0.18) !important;
    color: var(--violet-400) !important;
    border-color: rgba(255,128,199,0.3) !important;
    font-weight: 600 !important;
    box-shadow: none !important;
  }
  .sidebar-nav-disabled .stButton > button {
    color: var(--text-muted) !important;
    background: transparent !important;
    cursor: not-allowed !important;
    box-shadow: none !important;
    transform: none !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Spinner ├бРђЮРѓг├бРђЮРѓг */
  .stSpinner > div { border-top-color: var(--violet-500) !important; }

  /* ├бРђЮРѓг├бРђЮРѓг Download button ├бРђЮРѓг├бРђЮРѓг */
  .stDownloadButton > button {
    background: var(--bg-glass) !important;
    border: 1px solid var(--border-strong) !important;
    color: var(--violet-400) !important;
    box-shadow: none !important;
  }
  .stDownloadButton > button:hover {
    background: rgba(255,128,199,0.12) !important;
    box-shadow: 0 4px 16px rgba(255,128,199,0.2) !important;
  }

  /* ├бРђЮРѓг├бРђЮРѓг Scrollbar ├бРђЮРѓг├бРђЮРѓг */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-base); }
  ::-webkit-scrollbar-thumb { background: rgba(255,128,199,0.3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(255,128,199,0.5); }

  /* ├бРђЮРѓг├бРђЮРѓг Responsive ├бРђЮРѓг├бРђЮРѓг */
  @media (max-width: 768px) {
    .main .block-container { padding: 1rem 1rem 2rem 1rem !important; }
    h1 { font-size: 1.5rem !important; }
    .hero-banner { padding: 1.25rem 1.5rem !important; }
    .hero-title { font-size: 1.35rem !important; }
  }
</style>
""", unsafe_allow_html=True)
st.markdown("""
<style>
  :root {
    --bg-base: #fffaf2;
    --bg-surface: #ffffff;
    --bg-elevated: #fff4df;
    --bg-glass: rgba(255,255,255,0.78);
    --border-subtle: rgba(17,17,17,0.10);
    --border-strong: rgba(255,128,199,0.44);
    --violet-400: #d81159;
    --violet-500: #d81159;
    --violet-600: #111111;
    --violet-700: #000000;
    --teal-400: #ffbf00;
    --teal-500: #ffbf00;
    --rose-400: #d81159;
    --amber-400: #ffbf00;
    --green-400: #10a66a;
    --text-primary: #111111;
    --text-secondary: #4d463d;
    --text-muted: #948a7c;
  }

  html, body, [data-testid="stAppViewContainer"] {
    background: linear-gradient(135deg, rgba(255,128,199,0.16) 0%, rgba(255,191,0,0.10) 42%, rgba(255,250,242,1) 78%), #fffaf2 !important;
    color: #111111 !important;
  }
  [data-testid="stAppViewContainer"]::before {
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: linear-gradient(rgba(17,17,17,0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(17,17,17,0.035) 1px, transparent 1px) !important;
    background-size: 38px 38px;
    opacity: 0.55;
  }
  [data-testid="stAppViewContainer"]::after { display: none !important; }
  [data-testid="stSidebar"] {
    background: rgba(255,255,255,0.86) !important;
    border-right: 1px solid rgba(17,17,17,0.10) !important;
    box-shadow: 12px 0 40px rgba(17,17,17,0.05) !important;
    backdrop-filter: blur(18px);
  }

  h1, .hero-title { background: none !important; -webkit-text-fill-color: #111111 !important; color: #111111 !important; letter-spacing: 0 !important; }
  h2, h3 { color: #111111 !important; letter-spacing: 0 !important; }
  p, li, label, span { letter-spacing: 0 !important; }
  .brand-wordmark { display: inline-flex; align-items: baseline; flex-wrap: wrap; gap: 0; font-weight: 900; letter-spacing: 0 !important; line-height: 1; }
  .brand-wordmark .brand-pink { color: #d81159; }
  .brand-wordmark .brand-black { color: #111111; }
  .brand-mark { width: 34px; height: 34px; display: inline-grid; place-items: center; border-radius: 10px; background: #111111; color: #d81159; font-weight: 900; box-shadow: 5px 5px 0 #ffbf00; }

  .hero-banner { background: rgba(255,255,255,0.78) !important; border: 1px solid rgba(17,17,17,0.10) !important; border-radius: 18px !important; box-shadow: 0 18px 60px rgba(17,17,17,0.08) !important; }
  .hero-banner::before { content: '' !important; right: 1.5rem; width: 110px; height: 110px; border-radius: 30px; background: linear-gradient(135deg, #d81159 0%, #ffbf00 100%); opacity: 0.22 !important; transform: translateY(-50%) rotate(10deg) !important; }
  .hero-sub strong { color: #111111 !important; }
  .card, .card-accent, [data-testid="metric-container"], [data-testid="stExpander"] { background: rgba(255,255,255,0.82) !important; border: 1px solid rgba(17,17,17,0.10) !important; box-shadow: 0 14px 36px rgba(17,17,17,0.06) !important; }
  .card:hover, [data-testid="metric-container"]:hover, [data-testid="stExpander"]:hover { border-color: rgba(255,128,199,0.55) !important; box-shadow: 0 18px 48px rgba(255,128,199,0.16) !important; }
  .card-accent { background: linear-gradient(135deg, rgba(255,128,199,0.12), rgba(255,191,0,0.12)) !important; }

  .stButton > button, [data-testid="stButton"] button[kind="primary"] { background: #111111 !important; color: #fffaf2 !important; border: 1px solid #111111 !important; border-radius: 10px !important; box-shadow: 5px 5px 0 #ff80c7 !important; transform: translate(0,0) !important; font-weight: 700 !important; }
  .stButton > button:hover, [data-testid="stButton"] button[kind="primary"]:hover { background: #d81159 !important; color: #ffffff !important; box-shadow: 5px 5px 0 #ffbf00 !important; transform: translate(-1px,-1px) !important; border-color: #d81159 !important; }
  .sidebar-nav .stButton > button, .sidebar-nav-disabled .stButton > button { background: transparent !important; color: #4d463d !important; box-shadow: none !important; border-color: transparent !important; }
  .sidebar-nav-active .stButton > button { background: rgba(255,128,199,0.16) !important; color: #d81159 !important; border-color: rgba(255,128,199,0.38) !important; box-shadow: none !important; }

  [data-testid="stFileUploader"] { background: rgba(255,255,255,0.76) !important; border: 2px dashed rgba(255,128,199,0.62) !important; }
  [data-testid="stFileUploader"]:hover { background: rgba(255,191,0,0.08) !important; border-color: #111111 !important; }
  .stProgress > div > div { background: rgba(17,17,17,0.08) !important; }
  .stProgress > div > div > div, .score-bar-fill { background: linear-gradient(90deg, #d81159, #ffbf00) !important; }

  .step-badge { background: #111111 !important; color: #fffaf2 !important; box-shadow: 4px 4px 0 #ffbf00 !important; }
  .step-badge.running { background: #d81159 !important; color: #ffffff !important; animation: selected-pulse 1.45s ease-in-out infinite !important; }
  .step-badge.done { background: #10a66a !important; box-shadow: 4px 4px 0 #ffbf00 !important; }
  .step-row.running { background: rgba(255,128,199,0.12) !important; }
  .step-row.done { background: rgba(16,166,106,0.09) !important; }
  @keyframes selected-pulse { 0%, 100% { transform: translateY(0) scale(1); box-shadow: 4px 4px 0 #ffbf00; } 50% { transform: translateY(-2px) scale(1.04); box-shadow: 7px 7px 0 rgba(255,191,0,0.65); } }

  .loading-stage { position: relative; overflow: hidden; min-height: 280px; padding: 2.5rem; margin: 1rem 0; border-radius: 24px; background: #111111; color: #fffaf2; box-shadow: 0 30px 80px rgba(17,17,17,0.25); border: 1px solid rgba(255,128,199,0.2); }
  .loading-stage::before { content: '' !important; position: absolute; inset: -30%; background: radial-gradient(circle at 50% 50%, rgba(255,128,199,0.15) 0%, rgba(255,191,0,0.1) 40%, transparent 70%); animation: loading-spin 8s linear infinite; pointer-events: none; }
  .loading-topline { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; position: relative; z-index: 2; }
  .loading-chip { border: 1px solid rgba(255,128,199,0.3); border-radius: 999px; padding: 0.4rem 0.9rem; font-size: 0.72rem; font-weight: 700; color: #ff80c7; background: rgba(255,128,199,0.1); letter-spacing: 0.05em !important; text-transform: uppercase; }
  .loading-title { font-size: clamp(2rem, 3.5vw, 2.75rem); font-weight: 900; line-height: 1.1; margin: 0 0 1rem; color: #fffaf2; letter-spacing: -0.02em !important; position: relative; z-index: 2; }
  .loading-title .hot { background: linear-gradient(135deg, #ff80c7 0%, #ffbf00 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .loading-detail { color: rgba(255,250,242,0.75); max-width: 600px; margin-bottom: 2.2rem; font-size: 0.95rem; line-height: 1.6; position: relative; z-index: 2; }
  .loading-rail { display: grid; gap: 0.75rem; max-width: 100%; position: relative; z-index: 2; }
  .loading-scan-row { height: 6px; border-radius: 999px; background: rgba(255,250,242,0.08); overflow: hidden; position: relative; }
  .loading-scan-row span { display: block; width: 30%; height: 100%; border-radius: inherit; background: linear-gradient(90deg, #ff80c7, #ffbf00); animation: loading-scan-glow 2.5s cubic-bezier(0.4, 0, 0.2, 1) infinite; }
  .loading-scan-row:nth-child(2) span { animation-delay: 0.3s; width: 45%; }
  .loading-scan-row:nth-child(3) span { animation-delay: 0.6s; width: 20%; }
  .loading-scan-row:nth-child(4) span { animation-delay: 0.9s; width: 35%; }
  @keyframes loading-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  @keyframes loading-scan-glow { 0% { transform: translateX(-120%); } 50% { transform: translateX(250%); } 100% { transform: translateX(250%); } }

  code { background: rgba(255,128,199,0.16) !important; color: #111111 !important; }
  ::-webkit-scrollbar-track { background: #fffaf2; }
  ::-webkit-scrollbar-thumb { background: rgba(255,128,199,0.65); }
</style>
""", unsafe_allow_html=True)


