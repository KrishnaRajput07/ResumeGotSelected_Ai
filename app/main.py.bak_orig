def render_sidebar():
    with st.sidebar:
        # Logo / Brand
        st.markdown(f"""
        <div style="padding: 1.5rem 1.25rem 1rem 1.25rem; border-bottom: 1px solid rgba(17,17,17,0.10);">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
            <span class="brand-mark">R</span>
            {brand_wordmark("1.06rem")}
          </div>
          <div style="font-size:0.74rem; color:#4d463d; padding-left:2px;">Private resume shortlisting with evidence</div>
        </div>
        """, unsafe_allow_html=True)

        st.markdown("<div style='height:8px'></div>", unsafe_allow_html=True)
        st.markdown("<div style='padding:0 8px; font-size:0.7rem; color:#948a7c; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:4px;'>Navigation</div>", unsafe_allow_html=True)

        pages = [
            ("upload",     "├░┼ИРђюРђџ", "Upload Files"),
            ("calibrate",  "├б┼АРёб├»┬И┬Ј",  "Calibrate Rubric"),
            ("processing", "├б┼А┬А", "Processing"),
            ("results",    "├░┼ИРђю┼а", "Results"),
        ]

        for page_id, icon, label in pages:
            is_active = st.session_state.page == page_id
            is_disabled = True
            if page_id == "upload":
                is_disabled = False
            elif page_id == "calibrate":
                is_disabled = st.session_state.jd_parse_result is None
            elif page_id == "processing":
                is_disabled = st.session_state.frozen_rubric is None
            elif page_id == "results":
                is_disabled = st.session_state.pipeline_run is None

            if is_active:
                css_cls = "sidebar-nav-active"
                dot = "<span class='nav-dot'></span>" if page_id == "processing" and not st.session_state.run_complete else ""
            elif is_disabled:
                css_cls = "sidebar-nav-disabled"
                dot = "<span class='nav-lock'>├░┼ИРђЮРђЎ</span>"
            else:
                css_cls = "sidebar-nav"
                dot = ""

            st.markdown(f'<div class="{css_cls}">', unsafe_allow_html=True)
            if st.button(f"{icon}  {label}", key=f"nav_btn_{page_id}", disabled=is_disabled, use_container_width=True):
                st.session_state.page = page_id
                st.rerun()
            st.markdown('</div>', unsafe_allow_html=True)

        # Model info
        st.markdown("""
        <div style="border-top:1px solid rgba(255,128,199,0.15); margin-top:12px; padding:12px 16px 4px;">
          <div style="font-size:0.7rem; color:#948a7c; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">System</div>
        </div>
        """, unsafe_allow_html=True)

        st.markdown(f"""
        <div style="padding:0 12px;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
            <span style="width:7px;height:7px;border-radius:50%;background:#ffbf00;flex-shrink:0;"></span>
            <span style="font-size:0.78rem; color:#4d463d;">LLM: <code style="font-size:0.75rem">{settings.ollama_model}</code></span>
          </div>
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px;">
            <span style="width:7px;height:7px;border-radius:50%;background:#ff80c7;flex-shrink:0;"></span>
            <span style="font-size:0.78rem; color:#4d463d;">Embeddings: <code style="font-size:0.75rem">bge-small</code></span>
          </div>
        </div>
        """, unsafe_allow_html=True)

        if st.button("├░┼ИРђЮ┬Ї Check Ollama", key="sidebar_ollama_check"):
            with st.spinner("Checking connectivity..."):
                ok = llm_client.check_connectivity()
            if ok:
                st.success(f"├б┼ЊРђд Ollama ready")
            else:
                st.error(f"├б┬Ю┼њ Not reachable ├ѓ┬и Run: `ollama pull {settings.ollama_model}`")

        # Recent runs
        runs_dir = Path(settings.runs_dir)
        if runs_dir.exists():
            run_dirs = sorted(
                [d for d in runs_dir.iterdir() if d.is_dir()],
                key=lambda d: d.stat().st_mtime,
                reverse=True,
            )[:5]
            if run_dirs:
                st.markdown("""
                <div style="border-top:1px solid rgba(255,128,199,0.12); margin-top:12px; padding:12px 16px 4px;">
                  <div style="font-size:0.7rem; color:#948a7c; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:8px;">Recent Runs</div>
                </div>
                """, unsafe_allow_html=True)

                for rd in run_dirs:
                    candidates_dir = rd / "candidates"
                    n_cands = len(list(candidates_dir.glob("*.json"))) if candidates_dir.exists() else 0
                    run_label = rd.name[:14] + ("├бРѓг┬д" if len(rd.name) > 14 else "")

                    col_run, col_load = st.columns([3, 1])
                    with col_run:
                        st.markdown(f"<div style='font-size:0.78rem;color:#4d463d;padding:2px 12px'>├░┼ИРђю┬Ђ `{run_label}` <span style='color:#948a7c'>({n_cands})</span></div>", unsafe_allow_html=True)
                    with col_load:
                        if st.button("├бРђаРђћ", key=f"load_run_{rd.name}", help="Load this run"):
                            _load_run(rd)

        # Footer
        st.markdown("""
        <div style="border-top:1px solid rgba(255,128,199,0.12); margin-top:16px; padding:12px 16px;">
          <div style="font-size:0.72rem; color:#948a7c; text-align:center; line-height:1.6;">
            100% local ├ѓ┬и No data leaves your machine<br>Evidence-grounded ├ѓ┬и Explainable ranking
          </div>
        </div>
        """, unsafe_allow_html=True)


def _load_run(rd):
    """Load a previous run from disk."""
    rubric_path = rd / "rubric.json"
    if not rubric_path.exists():
        st.error("Rubric not found for this run.")
        return
    try:
        import json as _json
        rubric_data = _json.loads(rubric_path.read_text(encoding="utf-8"))
        loaded_rubric = FrozenRubric.model_validate(rubric_data)
        st.session_state.frozen_rubric = loaded_rubric

        candidates_dir = rd / "candidates"
        ranked_candidates, excluded_candidates = [], []
        if candidates_dir.exists():
            for f in candidates_dir.glob("*.json"):
                cand_data = _json.loads(f.read_text(encoding="utf-8"))
                cand_record = CandidateRecord.model_validate(cand_data)
                if cand_record.excluded:
                    excluded_candidates.append(cand_record)
                else:
                    ranked_candidates.append(cand_record)
        ranked_candidates.sort(key=lambda x: x.rank if x.rank is not None else 9999)

        total_submitted, shortlisted_count = 0, 0
        html_path = rd / "run_report.html"
        if html_path.exists():
            import re as _re
            html_text = html_path.read_text(encoding="utf-8")
            sub_match = _re.search(r"Submitted:\s*<strong>(\d+)</strong>", html_text)
            if sub_match: total_submitted = int(sub_match.group(1))
            short_match = _re.search(r"Shortlisted:\s*<strong>(\d+)</strong>", html_text)
            if short_match: shortlisted_count = int(short_match.group(1))
        if total_submitted == 0: total_submitted = len(ranked_candidates) + len(excluded_candidates)
        if shortlisted_count == 0: shortlisted_count = len(ranked_candidates) + len(excluded_candidates)

        # Load structured scores if JSONL mode was used
        structured_scores = []
        scores_file = rd / "structured_scores.json"
        if scores_file.exists():
            from schemas.candidate import StructuredCandidateScore
            import json as _json
            try:
                scores_data = _json.loads(scores_file.read_text(encoding="utf-8"))
                structured_scores = [StructuredCandidateScore.model_validate(s) for s in scores_data]
                st.session_state.is_jsonl_mode = True
            except Exception as se:
                logging.warning(f"Failed to load structured_scores.json: {se}")

        from schemas.candidate import RankedShortlist
        from pipeline.orchestrator import PipelineRun
        shortlist = RankedShortlist(
            run_id=rd.name,
            job_title=loaded_rubric.job_title,
            total_resumes_submitted=total_submitted,
            shortlisted_count=shortlisted_count,
            ranked_candidates=ranked_candidates,
            excluded_candidates=excluded_candidates,
            rubric_used=loaded_rubric.model_dump(mode="json"),
        )
        st.session_state.pipeline_run = PipelineRun(
            run_id=rd.name, run_dir=rd, frozen_rubric=loaded_rubric,
            shortlist=shortlist, completed=True,
            structured_scores=structured_scores
        )
        st.session_state.run_complete = True
        st.session_state.page = "results"
        st.rerun()
    except Exception as e:
        st.error(f"Failed to load run: {e}")


